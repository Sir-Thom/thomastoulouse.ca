{
	"name": "cvwebsite",
	"type": "module",
	"version": "1.3.0",
	"scripts": {
		"format": "prettier --config .prettierrc 'src/**/*.*' --write",
		"dev": "astro dev",
		"start": "prettier --config .prettierrc 'src/**/*.*' --write && pnpm astro dev --host",
		"build": "prettier --config .prettierrc 'src/**/*.*' --write && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"test": "jest",
		"E2E": "playwright test",
		"run": "dotenv -e .env astro dev",
		"deploy": "pnpm build && netlify deploy --prod"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.8",
		"@astrojs/internal-helpers": "^0.8.0",
		"@astrojs/netlify": "^7.0.6",
		"@astrojs/react": "^5.0.2",
		"@astrojs/sitemap": "^3.7.2",
		"@astrojs/tailwind": "^6.0.2",
		"@babel/preset-env": "^7.29.2",
		"@babel/preset-react": "^7.28.5",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "9.5.0",
		"@tailwindcss/vite": "^4.2.2",
		"astro": "^6.1.3",
		"babel-jest": "^29.7.0",
		"cookie": "^1.1.1",
		"devicons-react": "^1.5.0",
		"dompurify": "^3.3.3",
		"dotenv": "^17.4.0",
		"framer-motion": "^12.38.0",
		"prettier": "^3.8.1",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-icons": "^5.6.0",
		"tailwindcss": "^4.2.2",
		"three": "^0.183.2",
		"three-stdlib": "^2.36.1",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/dompurify": "^3.2.0",
		"@types/jest": "^29.5.14",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/three": "^0.183.1",
		"dompurify": "^3.0.6",
		"dotenv-webpack": "^9.0.0",
		"gltfjsx": "^6.5.3",
		"jest": "^30.3.0",
		"jest-environment-jsdom": "^30.3.0",
		"jsdom": "^26.1.0",
		"react-test-renderer": "^19.2.4",
		"sharp": "^0.34.5",
		"ts-jest": "^29.4.9",
		"ts-node": "^10.9.2",
		"vite": "^7.0.0"
	}
